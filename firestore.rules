rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }

    function email() {
      return request.auth.token.email.lower();
    }

    function isDirector() {
      return signedIn() && email() == "director@wise-jmco.com";
    }

    function userDoc() {
      return /databases/$(database)/documents/users/$(email());
    }

    function isActiveMember() {
      return signedIn()
        && exists(userDoc())
        && get(userDoc()).data.status == "active"
        && get(userDoc()).data.role in ["admin", "editor", "member"];
    }

    function isEditor() {
      return signedIn()
        && exists(userDoc())
        && get(userDoc()).data.status == "active"
        && get(userDoc()).data.role in ["admin", "editor"];
    }

    function isAdmin() {
      return signedIn()
        && exists(userDoc())
        && get(userDoc()).data.status == "active"
        && get(userDoc()).data.role == "admin";
    }

    // viewer = 外部パートナー向け名簿閲覧専用（member_directoryのみ・contents/users本体は読めない）
    function isDirectoryViewer() {
      return signedIn()
        && exists(userDoc())
        && get(userDoc()).data.status == "active"
        && get(userDoc()).data.role in ["admin", "viewer"];
    }

    function validUserPayload() {
      return request.resource.data.email is string
        && request.resource.data.email == request.resource.id
        && request.resource.data.role in ["admin", "editor", "member", "viewer"]
        && request.resource.data.status in ["active", "inactive"];
    }

    function validContentPayload() {
      return request.resource.data.title is string
        && request.resource.data.category is string
        && request.resource.data.type in ["video", "article", "document", "event", "link"]
        && request.resource.data.published is bool;
    }

    match /users/{userEmail} {
      allow read: if isAdmin() || (signedIn() && email() == userEmail);
      allow create: if (isAdmin() && validUserPayload())
        || (isDirector()
          && userEmail == "director@wise-jmco.com"
          && request.resource.data.role == "admin"
          && request.resource.data.status == "active"
          && validUserPayload());
      allow update: if isAdmin()
        && userEmail != email()
        && validUserPayload();
      allow delete: if isAdmin() && userEmail != email();
    }

    match /contents/{contentId} {
      allow read: if isEditor() || (isActiveMember() && resource.data.published == true);
      allow create, update: if isEditor() && validContentPayload();
      allow delete: if isAdmin();
    }

    // 現役会員の氏名+メールのみ（同期スクリプトが再構築・クライアント書込不可）
    match /member_directory/{entryId} {
      allow read: if isDirectoryViewer();
      allow write: if false;
    }

    // === SNSダッシュボード（sns-dashboard・2026-07-03追加） ===
    // 閲覧可: 運営スタッフ(admin/editor) または snsAccess==true が付与されたユーザー
    function snsAllowed() {
      return signedIn()
        && exists(userDoc())
        && get(userDoc()).data.status == "active"
        && (get(userDoc()).data.role in ["admin", "editor"]
          || get(userDoc()).data.get("snsAccess", false) == true);
    }

    // SNS集計データ（収集スクリプトがAdmin SDKで書込・クライアント書込不可）
    match /sns_data/{docId} {
      allow read: if snsAllowed();
      allow write: if false;
    }

    // アクセス申請: 本人が自分のメールIDで作成→麗華経由で山内さん承認
    match /access_requests/{requestEmail} {
      allow read: if isAdmin() || (signedIn() && email() == requestEmail);
      allow create: if signedIn()
        && email() == requestEmail
        && request.resource.data.email == requestEmail
        && request.resource.data.status == "pending"
        && request.resource.data.target in ["sns"];
      allow update, delete: if isAdmin();
    }
  }
}
